# Example configuration for gdoc2netcfg.
# Copy this file to gdoc2netcfg.toml and edit for your site:
#   cp gdoc2netcfg.toml.example gdoc2netcfg.toml
#
# The values below are for the Welland site. Monarto differences:
#   name = "monarto", domain = "monarto.mithis.com",
#   site_octet = 2, ipv6 prefix = "2404:e80:a137:" (same),
#   enabled generators = ["dnsmasq_internal"] only.

# ── Site-specific: change these per site ──────────────────────────
[site]
name = "welland"
domain = "welland.mithis.com"
public_ipv4 = "87.121.95.37"
site_octet = 1  # Second octet: 10.1.X.X for Welland, 10.2.X.X for Monarto
# all_sites (valid "Site" values) is read from the Sites sheet — see [sheets] below.

[sheets]
# Read sources: published CSV URLs per data source (read-only, no auth).
# Write access (spreadsheet_url + credentials below) is separate.
network = "https://docs.google.com/spreadsheets/d/e/2PACX-1vR5j6yiZCEv5YNoeVNLM4MMsxzBVjG4OtViBz7tXXF1LydHd8bCOOVWt7MvfVEPZtK0TeWgyxF3i9Tj/pub?gid=1476589425&single=true&output=csv"
iot = "https://docs.google.com/spreadsheets/d/e/2PACX-1vR5j6yiZCEv5YNoeVNLM4MMsxzBVjG4OtViBz7tXXF1LydHd8bCOOVWt7MvfVEPZtK0TeWgyxF3i9Tj/pub?gid=1695016218&single=true&output=csv"
vlan_allocations = "https://docs.google.com/spreadsheets/d/e/2PACX-1vR5j6yiZCEv5YNoeVNLM4MMsxzBVjG4OtViBz7tXXF1LydHd8bCOOVWt7MvfVEPZtK0TeWgyxF3i9Tj/pub?gid=208407908&single=true&output=csv"
# Sites tab: drives all_sites (valid "Site" values) and is cross-checked against [site]/[ipv6].
sites = "https://docs.google.com/spreadsheets/d/e/2PACX-1vR5j6yiZCEv5YNoeVNLM4MMsxzBVjG4OtViBz7tXXF1LydHd8bCOOVWt7MvfVEPZtK0TeWgyxF3i9Tj/pub?gid=582797138&single=true&output=csv"
# Edit URL of the same spreadsheet — used by 'zigbee update-sheet' for write access.
# Get this from your browser's address bar while the sheet is open.
# spreadsheet_url = "https://docs.google.com/spreadsheets/d/{ID}/edit"

# Sheet write credentials: set credentials_file for OAuth2 (browser-based,
# recommended) or service_account_file for a service account key.
# Real values belong in gdoc2netcfg.toml only (this file is a template).
credentials_file = ""  # Path to OAuth2 client_secret.json (Google Cloud Console)
token_cache = ".cache/google_oauth_token.json"
# service_account_file = ""  # Alternative: path to service account JSON key

[cache]
directory = ".cache"

# ── Site-specific: IPv6 prefixes may differ per site ─────────────
[ipv6]
# IPv6 prefixes for dual-stack address generation
# Format: 10.AA.BB.CCC -> {prefix}AABB::CCC
prefixes = [
    "2404:e80:a137:",    # ISP prefix (Launtel)
]
disabled_prefixes = [
    "2001:470:82b3:",    # HE.net prefix
]

# VLANs and network_subdomains are now derived from the
# VLAN Allocations spreadsheet sheet, not configured here.

# ── Site-specific: each site customizes this list. Monarto runs
# ── ["dnsmasq_internal", "dnsmasq_external", "nginx"]. ─────
[generators]
# Which generators to enable
enabled = ["dnsmasq_internal", "dnsmasq_external", "nagios", "nginx"]

[generators.dnsmasq_internal]
output_dir = "internal"

[generators.dnsmasq_external]
output_dir = "external"

[generators.nginx]
acme_webroot = "/var/www/acme"
# gdoc2netcfg_dir = "/etc/nginx/gdoc2netcfg"       # Deployment root for all generated nginx files
# sites_enabled_dir = "/etc/nginx/sites-enabled"     # Where nginx loads enabled site configs
# lua_healthcheck_path = "/usr/share/lua/5.1/"       # Path to lua-resty-upstream-healthcheck

[generators.letsencrypt]
auth_hook = "/opt/certbot/bin/certbot-hook-dnsmasq"
dnsmasq_conf_dir = "/etc/dnsmasq.d/external"
dnsmasq_conf = "/etc/dnsmasq.d/dnsmasq.external.conf"
dnsmasq_service = "dnsmasq@external"

[generators.nagios]
output = "nagios-switches.cfg"

[generators.topology]
output = "topology.dot"
show_unknown_macs = "false"

[generators.known_hosts]
output = "known_hosts"

# ── Home Assistant: the API + the one MQTT broker everything uses ─
[homeassistant]
url = "http://ha.welland.mithis.com:8123"  # REST + WebSocket API
# token = ""  # Long-lived access token from HA profile page
ssh_host = "ha.welland.mithis.com"      # SSH target for broker login registration

# The HA Mosquitto add-on — the single broker connection. The reachability
# publisher and the zigbee scanner connect here (as user/password); Tasmota
# devices are pointed at host/port.
[homeassistant.mqtt]
host = "ha.welland.mithis.com"
port = 1883
user = ""
password = ""

# ── Optional: Tasmota IoT device per-device MQTT credentials ──
# Broker host/port come from [homeassistant.mqtt]. mqtt_secret derives each
# device's MqttUser (tas-<id>) + MqttPassword; keep the toml 0600 (and mirror
# into any vault that re-derives). `gdoc2netcfg tasmota register-broker`
# registers the pre-hashed logins on the broker; `gdoc2netcfg tasmota configure`
# pushes the per-device login to the plugs.
[tasmota]
mqtt_secret = ""

# ── Optional: sensors2mqtt per-host MQTT credentials ─────────
# Issues a per-host broker login for each `local` host in the Network sheet's
# `Sensors` column (see `gdoc2netcfg sensors2mqtt`). Broker host/port come from
# [homeassistant.mqtt]; ssh_host (under [homeassistant]) is the cutover transport.
# mqtt_secret: high-entropy (openssl rand -hex 32); keep the toml 0600 and mirror
# the same value into the Ansible vault so Ansible recomputes identical passwords.
[sensors2mqtt]
mqtt_secret = ""
freshness_seconds = 900

# ── Optional: Zigbee2MQTT device scanning and sheet updates ──
# One Z2M instance per site: the broker is [homeassistant.mqtt] and the site
# name is [site].name. Presence of this section enables the hourly scan.
[zigbee]
sheet_name = "Zigbee Info"
